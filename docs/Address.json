{
    "openapi": "3.0.0",
    "info": {
        "title": "Address API",
        "version": "1.0.0",
        "description": "API de endereços - CRUD completo"
    },
    "paths": {
        "/addresses": {
            "get": {
                "summary": "Listar endereços",
                "parameters": [
                    {
                        "name": "page",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "default": 1
                        }
                    },
                    {
                        "name": "limit",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "default": 10
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Lista de endereços",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/AddressListResponse"
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "summary": "Criar endereço",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "id_user": {
                                        "type": "integer"
                                    },
                                    "name": {
                                        "type": "string"
                                    },
                                    "district": {
                                        "type": "string"
                                    },
                                    "city": {
                                        "type": "string"
                                    }
                                },
                                "required": [
                                    "id_user",
                                    "name",
                                    "district",
                                    "city"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Endereço criado",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Address"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/addresses/{id}": {
            "get": {
                "summary": "Obter endereço",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Endereço encontrado",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Address"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Endereço não encontrado"
                    }
                }
            },
            "put": {
                "summary": "Atualizar endereço",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "id_user": {
                                        "type": "integer"
                                    },
                                    "name": {
                                        "type": "string"
                                    },
                                    "district": {
                                        "type": "string"
                                    },
                                    "city": {
                                        "type": "string"
                                    }
                                },
                                "required": [
                                    "id_user",
                                    "name",
                                    "district",
                                    "city"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Endereço atualizado",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Address"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Endereço não encontrado"
                    }
                }
            },
            "delete": {
                "summary": "Deletar endereço",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Endereço deletado"
                    },
                    "404": {
                        "description": "Endereço não encontrado"
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "Address": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "id_user": {
                        "type": "integer"
                    },
                    "name": {
                        "type": "string"
                    },
                    "district": {
                        "type": "string"
                    },
                    "city": {
                        "type": "string"
                    }
                }
            },
            "AddressListResponse": {
                "type": "object",
                "properties": {
                    "page": {
                        "type": "integer"
                    },
                    "limit": {
                        "type": "integer"
                    },
                    "total": {
                        "type": "integer"
                    },
                    "next": {
                        "type": [
                            "integer",
                            "null"
                        ]
                    },
                    "data": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Address"
                        }
                    }
                }
            }
        }
    }
}