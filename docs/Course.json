{
    "openapi": "3.0.0",
    "info": {
        "title": "Course API",
        "version": "1.0.0",
        "description": "API de cursos - CRUD completo"
    },
    "paths": {
        "/courses": {
            "get": {
                "summary": "Listar cursos",
                "parameters": [
                    {
                        "name": "page",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "default": 1
                        }
                    },
                    {
                        "name": "limit",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "default": 10
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Lista de cursos",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/CourseListResponse"
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "summary": "Criar curso",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "name": {
                                        "type": "string"
                                    },
                                    "professor": {
                                        "type": "string"
                                    }
                                },
                                "required": [
                                    "name",
                                    "professor"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Curso criado",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Course"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/courses/{id}": {
            "get": {
                "summary": "Obter curso",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Curso encontrado",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Course"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Curso não encontrado"
                    }
                }
            },
            "put": {
                "summary": "Atualizar curso",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "name": {
                                        "type": "string"
                                    },
                                    "professor": {
                                        "type": "string"
                                    }
                                },
                                "required": [
                                    "name",
                                    "professor"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Curso atualizado",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Course"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Curso não encontrado"
                    }
                }
            },
            "delete": {
                "summary": "Deletar curso",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Curso deletado"
                    },
                    "404": {
                        "description": "Curso não encontrado"
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "Course": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "name": {
                        "type": "string"
                    },
                    "professor": {
                        "type": "string"
                    }
                }
            },
            "CourseListResponse": {
                "type": "object",
                "properties": {
                    "page": {
                        "type": "integer"
                    },
                    "limit": {
                        "type": "integer"
                    },
                    "total": {
                        "type": "integer"
                    },
                    "next": {
                        "type": [
                            "integer",
                            "null"
                        ]
                    },
                    "data": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Course"
                        }
                    }
                }
            }
        }
    }
}