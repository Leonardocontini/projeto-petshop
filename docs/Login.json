{
    "openapi": "3.0.0",
    "info": {
        "title": "Login API",
        "version": "1.0.0",
        "description": "Endpoint de login via email e senha"
    },
    "paths": {
        "/login": {
            "post": {
                "summary": "Autenticar usuário",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "email": {
                                        "type": "string"
                                    },
                                    "password": {
                                        "type": "string"
                                    }
                                },
                                "required": [
                                    "email",
                                    "password"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login bem-sucedido",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "token": {
                                            "type": "string"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Email ou senha inválidos"
                    }
                }
            }
        }
    }
}